# ============================================================
# NexusAI — Backend Configuration
# ============================================================

# === LLM Providers (uncomment the ones you want to use) ===

# Option A: Groq (fast inference, free tier)
GROQ_API_KEY=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
GROQ_MODEL=llama-3.3-70b-versatile

# Option B: Grok (xAI) — uses OpenAI-compatible API
# XAI_API_KEY=xai-your-key-here
# GROK_MODEL=grok-3

# Option C: OpenAI
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_MODEL=gpt-4o-mini

# Option D: Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# === Default provider: "groq" | "grok" | "openai" | "ollama" ===
LLM_PROVIDER=groq

# === ChromaDB ===
CHROMA_PERSIST_DIR=./chroma_db

# === Auth (set to true to enable login/register) ===
JWT_SECRET=change-this-to-a-random-secret-key-in-production
AUTH_ENABLED=false

# === Conversation Memory ===
MEMORY_WINDOW=10

# === Image Generation: "xai" | "dalle" | "stability-matrix" | "pollinations" | "none" ===
# Reuses XAI_API_KEY or OPENAI_API_KEY based on provider
IMAGE_PROVIDER=pollinations
STABILITY_MATRIX_URL=http://127.0.0.1:7860